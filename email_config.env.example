# Copy this file to email_config.env and fill in your SMTP details.
# Do not commit email_config.env (it contains secrets).
#
# Example for Microsoft 365 / Outlook:
# TIMESHEET_SMTP_HOST=smtp.office365.com
# TIMESHEET_SMTP_PORT=587
# TIMESHEET_SMTP_USER=your-account@fii-na.com
# TIMESHEET_SMTP_PASSWORD=your-app-password-or-account-password
# TIMESHEET_SMTP_FROM=your-account@fii-na.com
# Notification email is set in Admin → Settings (not here).

TIMESHEET_SMTP_HOST=
TIMESHEET_SMTP_PORT=587
TIMESHEET_SMTP_USER=
TIMESHEET_SMTP_PASSWORD=
TIMESHEET_SMTP_FROM=
